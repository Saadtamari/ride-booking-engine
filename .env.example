# ──────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` (the provided docker-compose already injects sane
# defaults, so you usually do NOT need a .env file when running via Docker).
# ──────────────────────────────────────────────────────────────────────────

# HTTP
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# PostgreSQL — the authoritative store (atomic conditional UPDATE lives here)
DATABASE_URL=postgres://rides:rides@localhost:5432/rides

# Redis — fast idempotency response cache (best-effort accelerator)
REDIS_URL=redis://localhost:6379

# How long a previously-seen Idempotency-Key is honoured (seconds). 24h default.
IDEMPOTENCY_TTL_SECONDS=86400

# Postgres pool size. MUST be >= your peak concurrency, because losing requests
# hold their connection while blocked on the contended row lock. 50 concurrent
# acceptors => keep this comfortably above 50.
PG_POOL_MAX=80
